{
  "manifest_version": 3,
  "name": "SlideKeys",
  "version": "0.1",
  "description": "Adds powerful keyboard shortcuts to Google Slides",
  "permissions": [
    "storage"
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background_script.js"
  },
  "commands": {
    "setLineSpacing115": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Set line spacing to 1.15"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/presentation/*",
        "https://docs.google.com/a*/presentation/*"
      ],
      "js": [
        "content_scripts/main_world_shortcuts.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://docs.google.com/presentation/*",
        "https://docs.google.com/a*/presentation/*"
      ],
      "js": [
        "content_scripts/utils.js",
        "content_scripts/keyboard_utils.js",
        "content_scripts/settings.js",
        "content_scripts/slide_actions.js",
        "content_scripts/commands.js",
        "help_dialog.js",
        "content_scripts/ui.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page_scripts/page_script.js",
        "fontello_svg_icon_font.css",
        "help_dialog.css",
        "help_dialog.html"
      ],
      "matches": ["https://docs.google.com/*"]
    }
  ]
}
